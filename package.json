{
  "name": "ludo237dotcom",
  "private": true,
  "description": "My personal website",
  "license": "MIT",
  "sideEffects": false,
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "scripts": {
    "postinstall": "remix setup",
    "build": "npm run build:css && npm run build:db && remix build",
    "build:css": "tailwindcss -m -i ./app/styles/tailwind.build.css -o app/styles/tailwind.css",
    "build:db": "npx prisma db push && npx prisma db seed",
    "dev:css": "tailwindcss -w -i ./app/styles/tailwind.build.css -o app/styles/tailwind.css",
    "dev": "concurrently \"npm run dev:css\" \"remix dev\"",
    "start": "cross-env NODE_ENV=production remix-serve build"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^1.3.0",
    "@fortawesome/free-brands-svg-icons": "^6.1.1",
    "@fortawesome/free-regular-svg-icons": "^6.1.1",
    "@fortawesome/free-solid-svg-icons": "^6.1.1",
    "@fortawesome/react-fontawesome": "^0.1.18",
    "@headlessui/react": "^1.6.1",
    "@prisma/client": "^3.13.0",
    "@remix-run/react": "^1.4.3",
    "@remix-run/serve": "^1.4.3",
    "@tailwindcss/forms": "^0.5.1",
    "@tailwindcss/typography": "^0.5.2",
    "clsx": "^1.1.1",
    "cross-env": "^7.0.3",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "remix": "^1.4.3",
    "tailwindcss": "^3.0.24",
    "tiny-invariant": "^1.2.0",
    "yup": "^0.32.11"
  },
  "devDependencies": {
    "@remix-run/dev": "^1.4.3",
    "@remix-run/eslint-config": "^1.4.3",
    "@types/markdown-it": "^12.2.3",
    "@types/react": "^17.0.44",
    "@types/react-dom": "^17.0.16",
    "autoprefixer": "^10.4.7",
    "concurrently": "^7.1.0",
    "esbuild-register": "^3.3.2",
    "eslint": "^8.14.0",
    "gray-matter": "^4.0.3",
    "markdown-it": "^12.3.2",
    "postcss": "^8.4.13",
    "prisma": "^3.13.0",
    "tiny-glob": "^0.2.9",
    "ts-node": "^10.7.0",
    "typescript": "^4.6.4"
  },
  "engines": {
    "node": ">=14"
  }
}
