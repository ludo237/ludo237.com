generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Post {
  id        String   @id @default(uuid())
  slug      String   @unique
  title     String
  excerpt   String
  markdown  String
  html      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
